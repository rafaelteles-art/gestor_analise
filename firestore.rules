rules_version = '2';

// Projeto v2-media-lab usa Supabase como banco de dados.
// Firestore foi criado automaticamente pelo App Hosting e nao e usado.
// Estas regras negam todo acesso de cliente. Acesso administrativo via Admin SDK
// (Cloud Functions, server-side) continua funcionando — ele ignora rules.
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
